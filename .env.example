# Copy to .env and adjust. All settings have sane defaults; see src/rag_qa/config.py.
RAG_ENV=production
RAG_HOST=0.0.0.0
RAG_PORT=8000

# Retrieval tuning (values chosen via eval harness, see README "Evaluation")
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.35

# Embeddings: "huggingface" (production) or "fake" (tests/CI only)
RAG_EMBEDDING_PROVIDER=huggingface
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM: "ollama" (production) or "fake" (tests/CI only)
RAG_LLM_PROVIDER=ollama
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=llama3.1:8b
RAG_LLM_TEMPERATURE=0.0
RAG_LLM_TIMEOUT_S=60

# Paths
RAG_INDEX_DIR=data/index
RAG_UPLOAD_DIR=data/uploads
